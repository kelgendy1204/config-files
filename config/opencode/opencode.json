{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "codescene": {
            "type": "local",
            "command": ["cs-mcp"],
            "enabled": true,
            "environment": {
                "CS_ACCESS_TOKEN": "$CS_ACCESS_TOKEN"
            }
        },
        "chrome-devtools": {
            "type": "local",
            "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
        }
    }
}
