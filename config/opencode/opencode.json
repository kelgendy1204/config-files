{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "external_directory": {
            "*": "ask"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "mcp": {
        "chrome-devtools": {
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ],
            "type": "local"
        },
        "codescene": {
            "command": [
                "cs-mcp"
            ],
            "enabled": true,
            "environment": {
                "CS_ACCESS_TOKEN": "$CS_ACCESS_TOKEN"
            },
            "type": "local"
        },
        "playwright": {
            "command": [
                "bash",
                "-c",
                "$HOME/config-files/scripts/playwright-mcp.sh"
            ],
            "type": "local"
        },
    },
    "provider": {
        "ollama": {
            "models": {
                "gemma4:26b": {
                    "name": "gemma4:26b"
                },
            },
            "name": "Ollama",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            }
        }
    }
}
