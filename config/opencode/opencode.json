{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "external_directory": {
            "*": "ask"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "mcp": {
        "chrome-devtools": {
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ],
            "type": "local"
        },
        "codescene": {
            "command": [
                "cs-mcp"
            ],
            "enabled": true,
            "environment": {
                "CS_ACCESS_TOKEN": "$CS_ACCESS_TOKEN"
            },
            "type": "local"
        },
        "playwright": {
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ],
            "type": "local"
        },
    },
}
