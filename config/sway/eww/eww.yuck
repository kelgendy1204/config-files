        (kb-section :icon "¾░é×" :title "NOTIFICATIONS"
          :entries {[
            ["¾░éø ", "Super + N",       "Dismiss notification"],
            ["¾░éø ", "Super + Shift+N", "Dismiss all"]
          ]})

        (box :class "kb-footer-line")
      ))))

(defwidget kb-section [icon title entries]
  (box
    :class "kb-section"
    :orientation "vertical"
    :space-evenly false
    :spacing 0
    (box
      :class "kb-section-title-row"
      :orientation "horizontal"
      :halign "center"
      :spacing 8
      (label :class "kb-section-icon" :text icon)
      (label :class "kb-section-title" :halign "center" :text title))
    (box
      :class "kb-section-body"
      :orientation "vertical"
      :space-evenly false
      :spacing 0
      (for entry in entries
        (kb-row :icon {entry[0]} :key {entry[1]} :val {entry[2]})))))

(defwidget kb-row [icon key val]
  (box
    :class "kb-row"
    :orientation "horizontal"
    :space-evenly false
    :spacing 0
    (label
      :class "kb-row-icon"
      :halign "start"
      :text icon)
    (label
      :class "kb-key"
      :halign "start"
      :hexpand false
      :wrap false
      :text key)
    (label
      :class "kb-val"
      :halign "end"
      :hexpand true
      :wrap true
      :text val)))
